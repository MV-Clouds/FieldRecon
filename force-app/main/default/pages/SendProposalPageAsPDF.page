<apex:page controller="SendProposalPageAsPDFController" renderAs="pdf" standardStylesheets="false" applyHtmlTag="false"
    applyBodyTag="false" showHeader="false" cache="false" action="{!createPDF}">
    <html>
    <head>
        <style>
            @page {
                margin-top: 16px;
                margin-left: 16px;
                margin-right: 16px;
                margin-bottom: 40px;
                size: A4;

                @bottom-left {
                    content: "Page " counter(page);
                    font-family: Arial, Helvetica, sans-serif;
                    color: #8B8B8B;
                    font-size: 12px;
                }
            }
            body {
                margin: 0;
                padding: 0;
            }
        </style>
    </head>
    <body>
        <apex:outputText value="{!strBody}" escape="false"/>
    </body>
    </html>
</apex:page>